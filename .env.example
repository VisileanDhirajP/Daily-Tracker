# ---------------------------------------------------------------------------
# Daily Tracker — environment variables
# Copy to `.env.local` and fill in. In mock mode you can leave everything blank.
# ---------------------------------------------------------------------------

# Data backend: "mock" (localStorage, no accounts needed) or "supabase".
# Defaults to "mock" when unset.
NEXT_PUBLIC_DATA_MODE=mock

# --- Supabase (required only when NEXT_PUBLIC_DATA_MODE=supabase) -----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client. Used by the send-to-manager route.
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (optional; enables real "Send to manager") ----------------------
# If unset, the app falls back to a downloadable file + a pre-filled mailto: draft.
RESEND_API_KEY=
EMAIL_FROM="Daily Tracker <onboarding@resend.dev>"

# Public site URL, used for Supabase auth redirects (password reset / verify).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
